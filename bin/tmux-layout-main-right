#!/usr/bin/env bash
# tmux-layout-main-right
# Rearrange current window: last pane takes right half, others stack evenly on left.

set -euo pipefail

WIN_W=$(tmux display-message -p '#{window_width}')
WIN_H=$(tmux display-message -p '#{window_height}')

# Pane IDs in index order (most recently created = last)
PANE_IDS=($(tmux list-panes -F '#{pane_id}'))
N=${#PANE_IDS[@]}

[[ $N -le 1 ]] && exit 0

if [[ $N -eq 2 ]]; then
    tmux select-layout even-horizontal
    exit 0
fi

LEFT_N=$(( N - 1 ))
LAST_ID="${PANE_IDS[-1]#%}"   # strip leading %

# Column widths (1 char for the vertical border)
RIGHT_W=$(( (WIN_W - 1) / 2 ))
LEFT_W=$(( WIN_W - RIGHT_W - 1 ))

# Row heights for left column (1 char between each row)
AVAIL_H=$(( WIN_H - (LEFT_N - 1) ))
ROW_H=$(( AVAIL_H / LEFT_N ))
REMAINDER=$(( AVAIL_H % LEFT_N ))

# tmux layout checksum (rotate-right-16 + add, matches layout.c)
checksum() {
    local s="$1" c=0 i ch ord
    for (( i = 0; i < ${#s}; i++ )); do
        ch="${s:i:1}"
        printf -v ord '%d' "'$ch"
        c=$(( ((c >> 1) | ((c & 1) << 15)) + ord ))
        c=$(( c & 0xFFFF ))
    done
    printf '%04x' $c
}

# Build top-to-bottom parts for the left column
LEFT_PARTS=""
Y=0
for (( i = 0; i < LEFT_N; i++ )); do
    ID="${PANE_IDS[$i]#%}"
    # Give any remainder rows to the last left pane
    (( i == LEFT_N - 1 )) && H=$(( ROW_H + REMAINDER )) || H=$ROW_H
    PART="${LEFT_W}x${H},0,${Y},${ID}"
    LEFT_PARTS="${LEFT_PARTS:+$LEFT_PARTS,}$PART"
    Y=$(( Y + H + 1 ))
done

# Left section: single pane or vertical stack [...]
if (( LEFT_N == 1 )); then
    LEFT_SEC="${LEFT_W}x${WIN_H},0,0,${PANE_IDS[0]#%}"
else
    LEFT_SEC="${LEFT_W}x${WIN_H},0,0[${LEFT_PARTS}]"
fi

# Right section: last pane, full height
RIGHT_SEC="${RIGHT_W}x${WIN_H},$(( LEFT_W + 1 )),0,${LAST_ID}"

# Wrap in a left-right split {...}
BODY="${WIN_W}x${WIN_H},0,0{${LEFT_SEC},${RIGHT_SEC}}"
CSUM=$(checksum "$BODY")
tmux select-layout "${CSUM},${BODY}"
